<UserControl xmlns="https://github.com/avaloniaui"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             xmlns:vm="using:LR9_12.ViewModels.Pages"
             xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
             xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
             mc:Ignorable="d" d:DesignWidth="400" d:DesignHeight="1200"
             x:DataType="vm:PubViewModel"
             x:Class="LR9_12.Views.Pages.PubView">

    <StackPanel>
        <ComboBox ItemsSource="{Binding Cocktails}"
                  SelectedItem="{Binding CurrentCocktail}"
                  HorizontalAlignment="Stretch"
                  Margin="15,10"
                  Padding="15"
                  Foreground="Black"
                  Background="#eeeeee"
                  BorderBrush="Black"
                  CornerRadius="10">
            <ComboBox.ItemTemplate>
                <DataTemplate>
                    <StackPanel>
                        <DockPanel>
                            <TextBlock DockPanel.Dock="Right" HorizontalAlignment="Right">
                                <TextBlock.Text>
                                    <MultiBinding StringFormat="Volume: {0}">
                                        <Binding Path="Volume"/>
                                    </MultiBinding>
                                </TextBlock.Text>
                            </TextBlock>
                            <TextBlock Text="{Binding Name}"/>
                        </DockPanel>
                    </StackPanel>
                </DataTemplate>
            </ComboBox.ItemTemplate>
        </ComboBox>
        <ItemsControl ItemsSource="{Binding Ingredients}"
                      Margin="15,10"
                      Foreground="Black">
            <ItemsControl.ItemTemplate>
                <DataTemplate>
                    <Border Margin="0,10,0,0"
                            CornerRadius="10"
                            BorderBrush="Gray" BorderThickness="1"
                            Padding="10">
                        <DockPanel>
                            <TextBlock DockPanel.Dock="Right" HorizontalAlignment="Right">
                                <TextBlock.Text>
                                    <MultiBinding StringFormat="Strength: {0}">
                                        <Binding Path="Strength"/>
                                    </MultiBinding>
                                </TextBlock.Text>
                            </TextBlock>
                            <TextBlock Text="{Binding Name}"/>
                        </DockPanel>
                    </Border>
                </DataTemplate>
            </ItemsControl.ItemTemplate>
        </ItemsControl>
    </StackPanel>
</UserControl>
