<UserControl xmlns="https://github.com/avaloniaui"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             xmlns:vm="using:LR9_12.ViewModels.Pages"
             xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
             xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
             mc:Ignorable="d" d:DesignWidth="400" d:DesignHeight="1200"
             x:DataType="vm:CurrencyConverterViewModel"
             x:Class="LR9_12.Views.Pages.CurrencyConverterView">

    <UserControl.Styles>
        <Style Selector="NumericUpDown">
            <Setter Property="FormatString" Value="N2"></Setter>
        </Style>
    </UserControl.Styles>

    <StackPanel>
        <DatePicker DayFormat="ddd dd"
                    MaxYear="{Binding MaxDate}"
                    Background="#eeeeee"
                    Foreground="Black"
                    BorderBrush="Black"
                    HorizontalAlignment="Stretch"
                    SelectedDate="{Binding Date}"/>
        <Border Margin="0,10"
                CornerRadius="5"
                BorderBrush="Gray" BorderThickness="1">
            <ScrollViewer VerticalScrollBarVisibility="Auto" Height="300">
                <ItemsControl ItemsSource="{Binding Rates}"
                              Margin="10"
                              Foreground="Black">
                    <ItemsControl.ItemTemplate>
                        <DataTemplate>
                            <Border CornerRadius="3"
                                    BorderBrush="Gray" BorderThickness="1"
                                    Padding="10">
                                <DockPanel>
                                    <TextBlock DockPanel.Dock="Right" HorizontalAlignment="Right">
                                        <TextBlock.Text>
                                            <MultiBinding StringFormat="{}{0} {1}">
                                                <Binding Path="Cur_OfficialRate"/>
                                                <Binding Path="Cur_Abbreviation"/>
                                            </MultiBinding>
                                        </TextBlock.Text>
                                    </TextBlock>
                                    <TextBlock Text="{Binding Cur_Name}"/>
                                </DockPanel>
                            </Border>
                        </DataTemplate>
                    </ItemsControl.ItemTemplate>
                </ItemsControl>
            </ScrollViewer>
        </Border>
        <Border Margin="0,5"
                CornerRadius="5"
                BorderBrush="Gray"
                BorderThickness="1">
            <UniformGrid Columns="2">
                <NumericUpDown Value="{Binding FromValue}"
                               Minimum="0"
                               Margin="5"
                               Foreground="Black"
                               Background="#eeeeee"
                               BorderBrush="Black"
                               VerticalContentAlignment="Center"
                               FontSize="18"/>
                <ComboBox DockPanel.Dock="Right"
                          Margin="5"
                          ItemsSource="{Binding Rates}"
                          SelectedItem="{Binding FromRate}"
                          HorizontalAlignment="Stretch"
                          Padding="10"
                          Foreground="Black"
                          BorderThickness="0"
                          BorderBrush="Black">
                    <ComboBox.ItemTemplate>
                        <DataTemplate>
                            <StackPanel>
                                <TextBlock Text="{Binding Cur_Name}"></TextBlock>
                            </StackPanel>
                        </DataTemplate>
                    </ComboBox.ItemTemplate>
                </ComboBox>
            </UniformGrid>
        </Border>
        <Border Margin="0,5"
                CornerRadius="5"
                BorderBrush="Gray"
                BorderThickness="1">
            <UniformGrid Columns="2">
                <NumericUpDown Value="{Binding ToValue}"
                               Minimum="0"
                               Margin="5"
                               Foreground="Black"
                               Background="#eeeeee"
                               BorderBrush="Black"
                               VerticalContentAlignment="Center"
                               FontSize="18"/>
                <ComboBox DockPanel.Dock="Right"
                          Margin="5"
                          ItemsSource="{Binding Rates}"
                          SelectedItem="{Binding ToRate}"
                          HorizontalAlignment="Stretch"
                          Padding="10"
                          Foreground="Black"
                          BorderThickness="0"
                          BorderBrush="Black">
                    <ComboBox.ItemTemplate>
                        <DataTemplate>
                            <StackPanel>
                                <TextBlock Text="{Binding Cur_Name}"></TextBlock>
                            </StackPanel>
                        </DataTemplate>
                    </ComboBox.ItemTemplate>
                </ComboBox>
            </UniformGrid>
        </Border>
    </StackPanel>
</UserControl>
